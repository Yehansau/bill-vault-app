{
  "expo": {
    "name": "BillVault",
    "slug": "BillVault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LogoPicture.png",
    "scheme": "billvault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow this app to access your camera"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/LogoPicture.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.billvault.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/LogoPicture.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LogoPicture.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow this app to access your camera"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
